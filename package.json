{
  "name": "elasticdash-test",
  "version": "0.1.11-alpha-1",
  "description": "AI-native test runner for ElasticDash workflow testing",
  "type": "module",
  "bin": {
    "elasticdash": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/inline-html.js && tsc",
